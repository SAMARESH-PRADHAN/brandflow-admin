{
  "name": "brandflow-admin-backend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "db:seed:force": "tsx src/db/seed.ts --force"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.4",
    "@neondatabase/serverless": "^1.0.0",
    "dotenv": "^16.5.0",
    "hono": "^4.7.10",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.16.5",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
